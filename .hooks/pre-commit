#!/bin/bash

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(js|jsx|ts|tsx)$" || true)
ESLINT="$(git rev-parse --show-toplevel)/node_modules/.bin/eslint"

if [[ -z "$STAGED_FILES" ]]; then
  echo "No JS/TS files staged. Skipping pre-commit checks."
  exit 0
fi

echo "Running ESLint on staged files..."

if [[ ! -x "$ESLINT" ]]; then
  echo "Please install ESLint first (npm i --save-dev eslint)"
  exit 1
fi

for FILE in $STAGED_FILES; do
  "$ESLINT" "$FILE"
done

echo "Running related staged tests with coverage gate..."
npm run test:staged

echo "Pre-commit checks passed."
